# packages/db/.env et apps/api/.env : file:./dev.db (relatif à packages/db/prisma/)
DATABASE_URL="file:./dev.db"
API_PORT=3001
ADMIN_URL=http://localhost:5173
JWT_ACCESS_SECRET=change-me-access-secret-minimum-16
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16char
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seed admin (`npm run db:seed` depuis la racine du repo)
# Le script charge aussi `apps/api/.env` : tu peux mettre ADMIN_* uniquement là-bas.
# Le seed met à jour le hash du compte existant (pas seulement à la création).
# Ne pas commit un vrai mot de passe dans un .env versionné.
ADMIN_EMAIL=admin@bleu-calanque.local
ADMIN_PASSWORD=change-me
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Demo

# Uploads sécurisés (API)
UPLOAD_STORAGE_DRIVER=inline
# CLAMAV_ENABLED=true
# CLAMAV_BINARY=clamdscan
# Si activé, un scan indisponible rejette le fichier (fail-closed).

# Rate limiting API (requêtes / THROTTLE_TTL_MS)
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120
# THROTTLE_AUTH_LIMIT=10

# Journal d’audit (suppression auto des entrées > N jours)
AUDIT_RETENTION_DAYS=60

# Emails (Resend) — https://resend.com
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev
# RESEND_FROM_NAME=Bleu Calanque

# Paiement en ligne (Stripe)
# STRIPE_SECRET_KEY=sk_test_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Estimation frais Stripe (finances) si balance_transaction pas encore synchronisée.
# Défaut = carte standard EEE : 1,5 % + 0,25 € (voir stripe.com/fr/pricing).
# STRIPE_FEE_ESTIMATE_PERCENT=1.5
# STRIPE_FEE_ESTIMATE_FIXED_CENTS=25
# PUBLIC_APP_URL=http://localhost:5173

# Futur S3 / Cloudflare R2 :
# UPLOAD_STORAGE_DRIVER=s3
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=bleu-calanque-uploads
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.example.com

# Inscription publique POST /auth/register (désactivée en production par défaut)
# AUTH_PUBLIC_REGISTER_ENABLED=true

# Prévisions météo mer (admin) — défaut : Port Ouest Marseille
# VITE_MARINE_FORECAST_LAT=43.3586
# VITE_MARINE_FORECAST_LON=5.2929
# VITE_MARINE_FORECAST_LABEL=Port Ouest
